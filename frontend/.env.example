# Frontend build configuration (Vite).
#
# Backend origin for a DECOUPLED deploy (Vercel frontend + Render backend).
# Set this in the Vercel project's Environment Variables, then redeploy.
#   VITE_API_URL=https://sentinel-soc-api.onrender.com
#
# Leave UNSET for local dev / Docker — the app then uses the same-origin
# proxy (Vite proxies /api and /ws to the backend on :8000).
VITE_API_URL=
