# Copy to .env and adjust. All vars are prefixed SOC_ (except ANTHROPIC_API_KEY).

# ── Auth ──────────────────────────────────────────────
SOC_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
SOC_JWT_EXPIRE_MINUTES=720

# ── CORS (Vite dev origins) ───────────────────────────
SOC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI (Claude) ───────────────────────────────────────
# Fast, cheap summarization model. Bump to claude-opus-4-8 for deeper analysis.
SOC_AI_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# ── Live NVD (NIST) CVE feed ──────────────────────────
SOC_NVD_ENABLED=1
# Optional NVD API key (raises rate limits): https://nvd.nist.gov/developers/request-an-api-key
SOC_NVD_API_KEY=
SOC_NVD_REFRESH_HOURS=6

# ── Live scanning (optional — needs privileges/tools) ──
# Real Nmap host discovery of SOC_SCAN_TARGET (requires the `nmap` binary).
SOC_SCAN_ENABLED=0
SOC_SCAN_TARGET=192.168.1.0/24
# Real Scapy packet capture (requires admin/root + Npcap on Windows).
SOC_SNIFF_ENABLED=0

# Seconds between packet broadcasts over WebSocket.
SOC_BROADCAST_INTERVAL=1.0
