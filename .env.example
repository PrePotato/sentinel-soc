# ─────────────────────────────────────────────────────────
# Docker Compose configuration. Copy to `.env` in this folder:
#     cp .env.example .env
# Compose substitutes these into docker-compose.yml (${VAR}).
# ─────────────────────────────────────────────────────────

# ── Ports (host side) ─────────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=8000

# ── PostgreSQL (event log) ────────────────────────────────
POSTGRES_USER=soc
POSTGRES_PASSWORD=soc_password
POSTGRES_DB=sentinel

# ── Auth ──────────────────────────────────────────────────
SOC_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
SOC_JWT_EXPIRE_MINUTES=720
SOC_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── AI (Claude) ───────────────────────────────────────────
# Fast, cheap summarization model. Bump to claude-opus-4-8 for deeper analysis.
SOC_AI_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# ── Live NVD (NIST) CVE feed ──────────────────────────────
SOC_NVD_ENABLED=1
# Optional API key (raises rate limits): https://nvd.nist.gov/developers/request-an-api-key
SOC_NVD_API_KEY=

# ── Optional real network scanning (needs privileges) ─────
SOC_SCAN_ENABLED=0
